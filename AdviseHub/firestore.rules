rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // Collection: users
    match /users/{userId} {
      allow read, write: if isAuthenticated();
    }

    // Collection: sessions
    match /sessions/{sessionId} {
      allow read, write: if isAuthenticated();
      
      // Subcollection: messages
      match /messages/{messageId} {
        allow read, write: if isAuthenticated();
      }
    }

    // Collection: customAdvisors
    match /customAdvisors/{advisorId} {
      allow read, write: if isAuthenticated();
    }

    // Collection: vault
    match /vault/{docId} {
      allow read, write: if isAuthenticated();
    }

    // Collection: documentChunks
    match /documentChunks/{chunkId} {
      allow read, write: if isAuthenticated();
    }

    // Collection: vaultDocuments
    match /vaultDocuments/{docId} {
      allow read, write: if isAuthenticated();
    }

    // Collection: councilResults
    match /councilResults/{resultId} {
      allow read, write: if isAuthenticated();
    }
    
    // Catch-all
    match /{path=**}/sharedSessions/{docId} {
      allow read: if true;
    }
  }
}
