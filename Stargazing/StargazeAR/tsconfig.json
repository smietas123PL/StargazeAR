{
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ]
    },
    "jsx": "react-native",
    "types": [
      "react",
      "react-native",
      "node"
    ]
  },
  "include": [
    "App.tsx",
    "index.ts",
    "src/**/*.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": [
    "stargazear_old",
    "node_modules"
  ],
  "extends": "expo/tsconfig.base"
}
