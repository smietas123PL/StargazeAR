{
  "expo": {
    "name": "StargazeAR",
    "slug": "stargazear",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "stargazear",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.smietaspl.stargazear",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-dev-client",
      [
        "expo-camera",
        {
          "cameraPermission": "StargazeAR potrzebuje dostępu do aparatu, aby wyświetlić nakładkę nieba nad obrazem z kamery."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "StargazeAR używa lokalizacji, aby obliczyć pozycje konstelacji nad Twoim horyzontem."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "3f7f33d8-dd04-4bd9-a60a-e52a39ef76a4"
      }
    },
    "owner": "smietaspl"
  }
}
